{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationDir": "../static",
    "outDir": "../static",
    "skipLibCheck": true,
    "baseUrl": "./src",
    "types": ["node", "jest"],
    "paths": {
      "~app/*": ["app/*"],
      "~features/*": ["features/*"],
      "~organizations/*": ["features/organizations/*"],
      "~entitlements/*": ["features/entitlements/*"],
      "~shared/*": ["shared/*"],
      "~i18n/*": ["i18n/*"]
    }
  }
}
