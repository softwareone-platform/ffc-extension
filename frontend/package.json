{
  "name": "ffc-operations-frontend",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "../static/index.js",
  "types": "../static/index.d.ts",
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "build:code": "node esbuild.config.js",
    "build": "npm run build:types && npm run build:code",
    "watch:types": "tsc -p tsconfig.json --watch",
    "watch:code": "node esbuild.config.js --watch",
    "start": "npm-run-all --parallel watch:types watch:code",
    "dev": "vite",
    "build:prod": "tsc -b && vite build"
  },
  "files": [
    "../static"
  ],
  "dependencies": {
    "@mpt-extension/sdk": "^0.0.5",
    "@mpt-extension/sdk-react": "^0.0.1",
    "@swo/design-system": "5.0.133",
    "@swo/design-tokens": "5.0.133",
    "@swo/ffc-api-model": "./swo-ffc-api-model-5.0.0-rc.1.tgz",
    "@swo/mp-api-model": "^5.2.524",
    "@swo/mp-status-chip": "^5.0.10",
    "@swo/rql-client": "^5.0.13",
    "@swo/service": "^5.0.2",
    "@tanstack/react-query": "^5.99.2",
    "@testing-library/react": "^16.3.2",
    "axios": "^1.13.5",
    "esbuild-sass-plugin": "^3.6.0",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^29.0.0",
    "jest-cli": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-html-reporter": "^4.0.1",
    "jest-junit": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
