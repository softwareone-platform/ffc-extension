{
  "name": "ffc-extension-frontend",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "../static/StandaloneRoot.js",
  "types": "../static/StandaloneRoot.d.ts",
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "build:code": "node esbuild.config.js",
    "build": "npm run build:types && npm run build:code",
    "watch:types": "tsc -p tsconfig.json --watch",
    "watch:code": "node esbuild.config.js --watch",
    "start": "npm-run-all --parallel watch:types watch:code",
    "dev": "vite",
    "build:prod": "tsc -b && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,scss,md}\"",
    "lint": "eslint \"src/**/*.{ts,tsx,js,mjs,cjs}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,mjs,cjs}\" --fix",
    "translations:sort": "node src/i18n/sortTranslations.ts",
    "fix:all": "npm-run-all translations:sort format lint:fix",
    "check:all": "npm run build",
    "check": "npm-run-all lint format:check",
    "test": "cross-env NODE_OPTIONS=\"--max_old_space_size=4096 --experimental-vm-modules\" jest --config=jest.config.js --passWithNoTests",
    "test:coverage": "cross-env NODE_OPTIONS=\"--max_old_space_size=4096 --experimental-vm-modules\" jest --config=jest-coverage.config.js --passWithNoTests --forceExit",
    "test:coverage:watch": "npm run test:coverage -- --watch"
  },
  "files": [
    "../static"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@mpt-extension/sdk": "^0.0.7",
    "@mpt-extension/sdk-react": "^0.0.7",
    "@swo/design-system": "5.0.133",
    "@swo/design-tokens": "5.0.133",
    "@swo/ffc-api-model": "./swo-ffc-api-model-5.0.0-rc.1.tgz",
    "@swo/mp-status-chip": "^5.0.10",
    "@swo/rql-client": "^5.0.13",
    "@swo/service": "^5.0.2",
    "@tanstack/react-query": "^5.99.2",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "axios": "^1.13.5",
    "esbuild-sass-plugin": "^3.6.0",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.7",
    "react-hook-form": "^7.56.2",
    "react-router-dom": "^6.30.3",
    "ts-jest": "^29.4.11",
    "zod": "^4.1.13",
    "zod-i18n-map": "^2.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/core": "^1.15.32",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^30.0.5",
    "jest-cli": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-html-reporter": "^4.0.1",
    "jest-junit": "^17.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
