{
  "name": "FFC Extension",
  "dockerComposeFile": [
    "../docker-compose.yaml",
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/app",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind",
    "source=${localEnv:HOME}/.config/starship.toml,target=/root/.config/starship.toml,type=bind",
    "source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume",
    "source=prek-cache-${devcontainerId},target=/root/.cache/prek,type=volume",
    "source=jetbrains-cache-${devcontainerId},target=/root/.cache/JetBrains,type=volume",
    "source=jetbrains-share-${devcontainerId},target=/root/.local/share/JetBrains,type=volume",
    "source=jetbrains-config-${devcontainerId},target=/root/.config/JetBrains,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/root/.claude",
    "PREK_HOME": "/root/.cache/prek"
  },
  "runServices": [
    "app",
    "db",
    "test_db"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "anthropic.claude-code",
        "knisterpeter.vscode-commitizen"
      ],
      "settings": {
        "python.terminal.activateEnvironment": false,
        "python.defaultInterpreterPath": "/opt/venv/bin/python"
      }
    },
    "jetbrains": {
      "backend": "PyCharm",
      "plugins": [
        "com.anthropic.code.plugin",
        "com.github.yhk1038.claude-code-gui"
      ]
    }
  }
}
